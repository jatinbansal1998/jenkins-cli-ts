{
  "name": "jenkins-cli-ts",
  "version": "0.7.12",
  "type": "module",
  "private": true,
  "module": "src/index.ts",
  "bin": {
    "jenkins-cli": "dist/jenkins-cli"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/jenkins-cli",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/jenkins-cli-linux-x64",
    "build:linux-x64-baseline": "bun build src/index.ts --compile --target=bun-linux-x64-baseline --outfile dist/jenkins-cli-linux-x64-baseline",
    "build:linux-x64-musl": "bun build src/index.ts --compile --target=bun-linux-x64-musl --outfile dist/jenkins-cli-linux-x64-musl",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/jenkins-cli-linux-arm64",
    "build:linux-arm64-musl": "bun build src/index.ts --compile --target=bun-linux-arm64-musl --outfile dist/jenkins-cli-linux-arm64-musl",
    "build:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/jenkins-cli-darwin-x64",
    "build:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/jenkins-cli-darwin-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/jenkins-cli-windows-x64.exe",
    "build:windows-x64-baseline": "bun build src/index.ts --compile --target=bun-windows-x64-baseline --outfile dist/jenkins-cli-windows-x64-baseline.exe",
    "build:bundle": "bun build src/index.ts --outfile dist/jenkins-cli-bundle --target bun",
    "build:all": "bun run build:bundle && bun run build:linux-x64 && bun run build:linux-x64-baseline && bun run build:linux-x64-musl && bun run build:linux-arm64 && bun run build:linux-arm64-musl && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64 && bun run build:windows-x64-baseline",
    "install:global": "bun run build && bun link",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint:fix && bun run format && bun run typecheck",
    "test": "bun test",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/yargs": "^17.0.35",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "prettier": "3.8.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "yargs": "^18.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css,md}": [
      "oxlint --fix",
      "prettier --write"
    ]
  }
}
