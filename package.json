{
  "name": "jenkins-cli-ts",
  "version": "0.7.24",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "module": "src/index.ts",
  "bin": {
    "jenkins-cli": "dist/jenkins-cli"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun scripts/build-local.ts",
    "build:all": "bun scripts/build.ts",
    "install:global": "bun run build && bun link",
    "post-merge:version": "bun scripts/post-merge-version.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint:fix && bun run format && bun run typecheck",
    "test": "bun test",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/yargs": "^17.0.35",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "3.9.4",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@clack/core": "1.4.3",
    "@clack/prompts": "^1.7.0",
    "cross-keychain": "^1.1.0",
    "yargs": "^18.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css,md}": [
      "oxlint --fix",
      "prettier --write"
    ]
  }
}
